# Backblaze B2 S3-compatible endpoint and object layout.
B2_ENDPOINT=s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003
B2_BUCKET=replace-me
B2_PREFIX=clusters/production/current/
B2_ARCHIVE_PREFIX=clusters/production/releases/

# Local publishing uses a prefix-scoped write key.
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me

# Flux bootstrap uses a separate prefix-scoped read-only key.
B2_READ_KEY_ID=replace-me
B2_READ_APPLICATION_KEY=replace-me

# Optional offline recovery key: read-only, scoped to
# clusters/production/releases/. Never add this key to GitHub or Kubernetes.
B2_RECOVERY_READ_KEY_ID=replace-me
B2_RECOVERY_READ_APPLICATION_KEY=replace-me
